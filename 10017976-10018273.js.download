/* eslint-disable */
if (!window.FP_17_TriggeredShared) {
    window.FP_17_TriggeredShared = true;
    (function trackingShared() {
        function gtagTracking(convert_category, convert_action, convert_label) {
            window.gtag('event', 'Convert_Test_Tracking', {
                convert_category,
                convert_action,
                convert_label,
                send_to: 'G-TFJP814ZR2'
            });
        }


        function delegateEvent(el, evt, sel, handler) {
            el.addEventListener(evt, function (event) {
                let t = event.target;
                while (t && t !== this) {
                    if (t.matches(sel)) {
                        event.matchedSelector = t;
                        handler.call(t, event);
                    }
                    t = t.parentNode;
                }
            }, true);
        }

        function waitUntil(predicate, time = 10000) {
            return new Promise(((resolve) => {
                let int = setInterval(() => {
                    if (predicate()) {
                        resolve(predicate());
                        clearInterval(int);
                        int = null;
                    }
                }, 30);
                setTimeout(() => {
                    if (int !== null) {
                        clearInterval(int);
                        console.log('condition false');
                    }
                }, time);
            }));
        }

        function convertGoal(id) {
            window._conv_q = window._conv_q || [];
            _conv_q.push(['triggerConversion', id]);
        }

        waitUntil(() => window.gtag !== undefined).then(() => {

            delegateEvent(document, 'mousedown', 'body', ({ target }) => {

                if (window.location.pathname !== '/new-challenge') return;

                // Click on continue payment - floating widget
                if (target.closest('.fp_17_paymentCta')) {
                    convertGoal("100151552");
                    gtagTracking("FP_17", "Click on continue payment - floating widget", "");
                }

                // Click on price - floating widget
                if (target.closest('.fp_17_totalPrice')) {
                    convertGoal("100151553");
                    gtagTracking("FP_17", "Click on price - floating widget", "");
                }

                // Click on view summary - floating widget
                if (target.closest('.fp_17_viewSummaryCta')) {
                    convertGoal("100151554");
                    gtagTracking("FP_17", "Click on view summary - floating widget", "");
                }

                // payment option interaction
                if (target.closest('form footer button[role="radio"]')) {
                    const button = target.closest('button');
                    const label = button.closest('div:not([role="radiogroup"]').querySelector('label');
                    if (label && label.textContent.trim().toLowerCase().includes('select payment method')) {
                        convertGoal('100150755');
                        gtagTracking("FP_17", "payment option interaction", `${button.getAttribute('aria-label')}`);
                    }
                }

                // click on plus icon
                if (target.closest('nav.fixed a[href="/new-challenge"]')) {
                    convertGoal("100149768");
                    gtagTracking("FP_17", "click on plus icon", "click on plus icon");
                }

                // Interaction with more option items
                if (target.closest('[data-slot="dropdown-menu-content"] > a, [data-slot="dropdown-menu-content"] > button')) { 
                    const item = target.closest('a, button');
                    const itemText = item.textContent.trim();
                    convertGoal("100151560");
                    gtagTracking("FP_17", "Interaction with more option items", `Interaction with more option items - ${itemText}`);
                }

                // INTERACTION WITH NAVIGATION BARS
                if(target.closest('nav.fixed a')) {
                    const textObj = {
                        '/dashboard': 'Dashboard',
                        '/accounts': 'Account',
                        '/new-challenge': 'New Challenge',
                    }
                    const navText = textObj[target.closest('nav.fixed a').getAttribute('href')];
                    convertGoal("100147522");
                    gtagTracking("FP_17", "INTERACTION WITH NAVIGATION BARS", `INTERACTION WITH NAVIGATION BARS - ${navText ? navText : ''}`);
                }

                // challenge type clicks
                if (target.closest('form [data-slot="radio-group"] label:has(button[value*="Step"]), form [data-slot="radio-group"] label:has(button[value="Zero"])')) {
                    const challengeType = target.closest('label').querySelector('button').value.split(' ')[0];
                    convertGoal("100147534");
                    gtagTracking("FP_17", "challenge type clicks", `challenge type clicks - ${challengeType}`);
                }
                // MODEL TYPES ( TWO STEP )
                if (target.closest('form label:has(button[value*="FundingPips"])')) {
                    const modelType = target.closest('label').querySelector('button').value;
                    convertGoal("100147523");
                    gtagTracking("FP_17", "MODEL TYPES ( TWO STEP )", `MODEL TYPES ( TWO STEP ) - ${modelType}`);
                }
                // FUNDING PIP PROFIT TARGET INTERACTION
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:not(:has(+ div)) label')) {
                    const isProfitTarget = target.closest('div[role="radiogroup"]').closest('div:not([role="radiogroup"]').querySelector('label').textContent.includes('Profit Target');
                    if (isProfitTarget) {
                        const label = target.closest('label').querySelector('.text-sm').textContent;
                        convertGoal("100147524");
                        gtagTracking("FP_17", "FUNDING PIP PROFIT TARGET INTERACTION", `FUNDING PIP PROFIT TARGET INTERACTION - ${label}`);
                    }
                }

                // FUNDING PIP swap free interaction
                // FUNDINGPIP PRO swap free interaction
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:not(:has(+ div)) label')) {
                    const isSwapFree = target.closest('div[role="radiogroup"]').closest('div:not([role="radiogroup"]').querySelector('label').textContent.includes('Swap Free');
                    if (isSwapFree) {
                        const isProSelected = document.body.querySelector('form label:has(button[data-state="checked"][value*="Pro"])');
                        const label = target.closest('label').querySelector('.text-sm').textContent;
                        if (isProSelected) {
                            // FUNDINGPIP PRO swap free interaction
                            convertGoal("100151643");
                            gtagTracking("FP_17", "FUNDINGPIP PRO swap free interaction", `FUNDINGPIP PRO swap free interaction - ${label}`);
                        } else {
                            // FUNDING PIP swap free interaction
                            convertGoal("100149894");
                            gtagTracking("FP_17", "FUNDING PIP swap free interaction", `FUNDING PIP swap free interaction - ${label}`);
                        }
                    }
                }

                // FUNDINGPIP PRO REWARD CYCLE INTERACTION
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:has(+div) label')) {
                    const label = target.closest('label').querySelector('.text-sm').textContent;
                    convertGoal("100147525");
                    gtagTracking("FP_17", "FUNDINGPIP PRO REWARD CYCLE INTERACTION", `FUNDINGPIP PRO REWARD CYCLE INTERACTION - ${label}`);
                }

                // ACCOUNT SIZES INTERACTION
                if (target.closest('form div[data-slot="radio-group"] label:has(button[value*="000"])')) {
                    const label = target.closest('label').querySelector('button').value;
                    convertGoal("100147533");
                    gtagTracking("FP_17", "ACCOUNT SIZES INTERACTION", `ACCOUNT SIZES INTERACTION - ${label}`);
                }
                // TRADE PLATFROM INTERACTION
                if (target.closest('form div[data-slot="radio-group"] label:has(button[value*="mt5"]), form div[data-slot="radio-group"] label:has(button[value*="matchtrader"]), form div[data-slot="radio-group"] label:has(button[value*="ctrader"])')) {
                    const label = target.closest('label').querySelector('button').value;
                    convertGoal("100147532");
                    gtagTracking("FP_17", "TRADE PLATFROM INTERACTION", `TRADE PLATFROM INTERACTION - ${label}`);
                }

                // INTERACTION WITH BILLING DETAIL FIELDS
                if (target.closest('[data-slot="popover-content"] [data-slot="command-item"][data-value]')) {
                    const isFormOpen = document.body.querySelector('main form #billing-details button[data-state="open"]');
                    if (isFormOpen) {
                        const label = target.closest('[data-slot="command-item"]').dataset.value;
                        convertGoal("100149895");
                        gtagTracking("FP_17", "INTERACTION WITH BILLING DETAIL FIELDS", `INTERACTION WITH BILLING DETAIL FIELDS - ${label}`);
                    }
                    
                }

                // COUPON CODE APPLY CTA CLICKS
                if (target.closest('form div >div:has(input[placeholder*="coupon"]) + button')) {
                    convertGoal("100147527");
                    gtagTracking("FP_17", "COUPON CODE APPLY CTA CLICKS", "COUPON CODE APPLY CTA CLICKS");
                }
                // ENTER COUPON FIELD INTERATION
                if (target.closest('form div input[placeholder*="coupon"]')) {
                    convertGoal("100147528");
                    gtagTracking("FP_17", "ENTER COUPON FIELD INTERATION", "ENTER COUPON FIELD INTERATION");
                }
                // CLICK ON I AGREE CHECKBOX
                if (target.closest('form button#terms-agreement')) {
                    convertGoal("100147529");
                    gtagTracking("FP_17", "CLICK ON I AGREE CHECKBOX", "CLICK ON I AGREE CHECKBOX");
                }
                // CLICK ON CONTINUE PAYEMNT CTA
                if (target.closest('form section button[type="submit"]')) {
                    convertGoal("100147530");
                    gtagTracking("FP_17", "CLICK ON CONTINUE PAYEMNT CTA", "CLICK ON CONTINUE PAYEMNT CTA");
                }
                // CLICK ON TERM OF USE AND TERM CONDITION
                if (target.closest('form footer a[href*="term"]')) {
                    // console.log('CLICK ON TERM OF USE AND TERM CONDITION');
                    convertGoal("100147531");
                    gtagTracking("FP_17", "CLICK ON TERM OF USE AND TERM CONDITION", "CLICK ON TERM OF USE AND TERM CONDITION");
                }

            });

            // INTERACTION WITH NAVIGATION BARS
            delegateEvent(document, 'pointerdown', 'nav.fixed button[aria-haspopup="menu"]', () => {
                convertGoal("100147522");
                gtagTracking("FP_17", "INTERACTION WITH NAVIGATION BARS", "Menu");
            });


            delegateEvent(document, 'focusout', 'main form #billing-details input', ({ target }) => {
                if (window.location.pathname !== '/new-challenge') return;
                // INTERACTION WITH BILLING DETAIL FIELDS
                const inputValue = target.closest('input').value;
                convertGoal("100149895");
                gtagTracking("FP_17", "INTERACTION WITH BILLING DETAIL FIELDS", `INTERACTION WITH BILLING DETAIL FIELDS - ${inputValue}`);
            });

            function getScrollPercent(el) {
                return (el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100;
            }

            let check_25 = false;
            let check_50 = false;
            let check_75 = false;
            let check_98 = false;

            function ScrollEvent(main) {
                if (window.location.pathname !== '/new-challenge') return;
                const scrollPercent = getScrollPercent(main);

                if (scrollPercent >= 25 && !check_25) {
                    check_25 = true;
                    convertGoal('100145388');
                    gtagTracking('FP_17', 'PAGE SCROLL', 'Scroll_25%');
                }

                if (scrollPercent >= 50 && !check_50) {
                    check_50 = true;
                    convertGoal('100145389');
                    gtagTracking('FP_17', 'PAGE SCROLL', 'Scroll_50%');
                }

                if (scrollPercent >= 75 && !check_75) {
                    check_75 = true;
                    convertGoal('100145390');
                    gtagTracking('FP_17', 'PAGE SCROLL', 'Scroll_75%');
                }

                if (scrollPercent >= 98 && !check_98) {
                    check_98 = true;
                    convertGoal('100145391');
                    gtagTracking('FP_17', 'PAGE SCROLL', 'Scroll_100%');
                }

                if (check_25 && check_50 && check_75 && check_98) {
                    main.removeEventListener('scroll', ScrollEvent);
                }
            }

            waitUntil(() => document.querySelector('main') != null).then(() => {
                const main = document.querySelector('main');
                main.addEventListener('scroll', () => ScrollEvent(main));
            });

        });
    }());
}
