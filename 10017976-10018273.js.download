                    }
                    // GET FUNDED CTA CLICK & CONTINUE WITH GOOGLE CLICK
                    if (target.closest('button[type="submit"]')) {
                        const button = target.closest('button').textContent;
                        if (button.includes('Funded')) {
                            // console.log('GET FUNDED CTA CLICK ');
                            // convertGoal("100149919");
                            // gtagTracking("FP_14", "GET FUNDED CTA CLICK", "Interaction");
                        } else if (button.includes('Google')) {
                            // console.log('CONTINUE WITH GOOGLE CLICK ');
                            convertGoal("100149920");
                            gtagTracking("FP_14", "CONTINUE WITH GOOGLE CLICK", "Interaction");
                        }
