        const getBtnText = (btn) => {
            if (btn.querySelector('svg.lucide-moon')) return 'Dark Mode';
            if (btn.querySelector('svg.lucide-sun')) return 'Light Mode';
            return '';
        }

        waitUntil(() => window.gtag !== undefined).then(() => {

            delegateEvent(document, 'mousedown', 'body', ({ target }) => {

                if (window.location.pathname !== '/new-challenge') return;

                // click on plus icon
                if (target.closest('a[aria-label="Go to Dashboard"] + a[href="/new-challenge"]')) {
                    convertGoal("100149768");
                    gtagTracking("FP_11", "click on plus icon", "click on plus icon");
                }

                // INTERACTION WITH NAVIGATION BARS
                if(target.closest('nav[aria-label="Main Navigation"] a[title]')) {
                    const buttonTitle = target.closest('nav[aria-label="Main Navigation"] a[title]').getAttribute('title');
                    convertGoal("100147522");
                    gtagTracking("FP_11", "INTERACTION WITH NAVIGATION BARS", `INTERACTION WITH NAVIGATION BARS ${buttonTitle}`);
                }

                // INTERACTION WITH NAVIGATION BARS
                if (target.closest('div > a, div > button')) {
                    const targetBtn = target.closest('div > a, div > button');
                    const isNavBtn = targetBtn.closest('div').querySelector('a[title="Settings"]');
                    if (isNavBtn) {
                        const buttonTitle = targetBtn.getAttribute('title') || targetBtn.getAttribute('aria-label') || getBtnText(targetBtn);
                        convertGoal("100147522");
                        gtagTracking("FP_11", "INTERACTION WITH NAVIGATION BARS", `INTERACTION WITH NAVIGATION BARS ${buttonTitle}`);
                    }
                   
                }

                // challenge type clicks
                if (target.closest('form [data-slot="radio-group"] label:has(button[value*="Step"]), form [data-slot="radio-group"] label:has(button[value="Zero"])')) {
                    const challengeType = target.closest('label').querySelector('button').value.split(' ')[0];
                    convertGoal("100147534");
                    gtagTracking("FP_11", "challenge type clicks", `challenge type clicks - ${challengeType}`);
                }
                // MODEL TYPES ( TWO STEP )
                if (target.closest('form label:has(button[value*="FundingPips"])')) {
                    const modelType = target.closest('label').querySelector('button').value;
                    convertGoal("100147523");
                    gtagTracking("FP_11", "MODEL TYPES ( TWO STEP )", `MODEL TYPES ( TWO STEP ) - ${modelType}`);
                }
                // FUNDING PIP PROFIT TARGET INTERACTION
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:not(:has(+ div)) label')) {
                    const isProfitTarget = target.closest('div[role="radiogroup"]').closest('div:not([role="radiogroup"]').querySelector('label').textContent.includes('Profit Target');
                    if (isProfitTarget) {
                        const label = target.closest('label').querySelector('.text-sm').textContent;
                        convertGoal("100147524");
                        gtagTracking("FP_11", "FUNDING PIP PROFIT TARGET INTERACTION", `FUNDING PIP PROFIT TARGET INTERACTION - ${label}`);
                    }
                }

                // FUNDING PIP swap free interaction
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:not(:has(+ div)) label')) {
                    const isSwapFree = target.closest('div[role="radiogroup"]').closest('div:not([role="radiogroup"]').querySelector('label').textContent.includes('Swap Free');
                    if (isSwapFree) {
                        const label = target.closest('label').querySelector('.text-sm').textContent;
                        convertGoal("100149894");
                        gtagTracking("FP_11", "FUNDING PIP swap free interaction", `FUNDING PIP swap free interaction - ${label}`);
                    }
                }

                // FUNDINGPIP PRO REWARD CYCLE INTERACTION
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:has(+div) label')) {
                    const label = target.closest('label').querySelector('.text-sm').textContent;
                    convertGoal("100147525");
                    gtagTracking("FP_11", "FUNDINGPIP PRO REWARD CYCLE INTERACTION", `FUNDINGPIP PRO REWARD CYCLE INTERACTION - ${label}`);
                }

                // ACCOUNT SIZES INTERACTION
                if (target.closest('form div[data-slot="radio-group"] label:has(button[value*="000"])')) {
                    const label = target.closest('label').querySelector('button').value;
                    convertGoal("100147533");
                    gtagTracking("FP_11", "ACCOUNT SIZES INTERACTION", `ACCOUNT SIZES INTERACTION - ${label}`);
                }
                // TRADE PLATFROM INTERACTION
                if (target.closest('form div[data-slot="radio-group"] label:has(button[value*="mt5"]), form div[data-slot="radio-group"] label:has(button[value*="matchtrader"]), form div[data-slot="radio-group"] label:has(button[value*="ctrader"])')) {
                    const label = target.closest('label').querySelector('button').value;
                    convertGoal("100147532");
                    gtagTracking("FP_11", "TRADE PLATFROM INTERACTION", `TRADE PLATFROM INTERACTION - ${label}`);
                }

                // INTERACTION WITH BILLING DETAIL FIELDS
                if (target.closest('[data-slot="popover-content"] [data-slot="command-item"][data-value]')) {
                    const isFormOpen = document.body.querySelector('main form #billing-details button[data-state="open"]');
                    if (!isFormOpen) return;
                    const label = target.closest('[data-slot="command-item"]').dataset.value;
                    convertGoal("100149895");
                    gtagTracking("FP_11", "INTERACTION WITH BILLING DETAIL FIELDS", `INTERACTION WITH BILLING DETAIL FIELDS - ${label}`);
                }

                // COUPON CODE APPLY CTA CLICKS
                if (target.closest('form div >div:has(input[placeholder*="coupon"]) + button')) {
                    convertGoal("100147527");
                    gtagTracking("FP_11", "COUPON CODE APPLY CTA CLICKS", "COUPON CODE APPLY CTA CLICKS");
                }
                // ENTER COUPON FIELD INTERATION
                if (target.closest('form div input[placeholder*="coupon"]')) {
                    convertGoal("100147528");
                    gtagTracking("FP_11", "ENTER COUPON FIELD INTERATION", "ENTER COUPON FIELD INTERATION");
                }
                // CLICK ON I AGREE CHECKBOX
                if (target.closest('form button#terms-agreement')) {
                    convertGoal("100147529");
                    gtagTracking("FP_11", "CLICK ON I AGREE CHECKBOX", "CLICK ON I AGREE CHECKBOX");
                }
                // CLICK ON CONTINUE PAYEMNT CTA
                if (target.closest('form section button[type="submit"]')) {
                    convertGoal("100147530");
                    gtagTracking("FP_11", "CLICK ON CONTINUE PAYEMNT CTA", "CLICK ON CONTINUE PAYEMNT CTA");
                }
                // CLICK ON TERM OF USE AND TERM CONDITION
                if (target.closest('form footer a[href*="term"]')) {
                    // console.log('CLICK ON TERM OF USE AND TERM CONDITION');
                    convertGoal("100147531");
                    gtagTracking("FP_11", "CLICK ON TERM OF USE AND TERM CONDITION", "CLICK ON TERM OF USE AND TERM CONDITION");
                }

                // payment option interaction
                if (target.closest('form footer button[role="radio"]')) {
                    const button = target.closest('button');
                    const label = button.closest('div:not([role="radiogroup"]').querySelector('label');
                    if (label && label.textContent.trim().toLowerCase().includes('select payment method')) {
                        convertGoal('100150755');
                        gtagTracking("FP_11", "payment option interaction", `${button.getAttribute('aria-label')}`);
                    }
                }
            });



            delegateEvent(document, 'focusout', 'main form #billing-details input', ({ target }) => {
                if (window.location.pathname !== '/new-challenge') return;
                // INTERACTION WITH BILLING DETAIL FIELDS
                const inputValue = target.closest('input').value;
                convertGoal("100149895");
                gtagTracking("FP_11", "INTERACTION WITH BILLING DETAIL FIELDS", `INTERACTION WITH BILLING DETAIL FIELDS - ${inputValue}`);
            });

            function getScrollPercent(el) {
                return (el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100;
            }

            let check_25 = false;
            let check_50 = false;
            let check_75 = false;
            let check_98 = false;

            function ScrollEvent(main) {
                if (window.location.pathname !== '/new-challenge') return;
                const scrollPercent = getScrollPercent(main);

                if (scrollPercent >= 25 && !check_25) {
                    check_25 = true;
                    convertGoal('100145388');
                    gtagTracking('FP_11', 'PAGE SCROLL', 'Scroll_25%');
                }

                if (scrollPercent >= 50 && !check_50) {
                    check_50 = true;
                    convertGoal('100145389');
                    gtagTracking('FP_11', 'PAGE SCROLL', 'Scroll_50%');
                }

                if (scrollPercent >= 75 && !check_75) {
                    check_75 = true;
                    convertGoal('100145390');
                    gtagTracking('FP_11', 'PAGE SCROLL', 'Scroll_75%');
                }

                if (scrollPercent >= 98 && !check_98) {
                    check_98 = true;
                    convertGoal('100145391');
                    gtagTracking('FP_11', 'PAGE SCROLL', 'Scroll_100%');
                }

                if (check_25 && check_50 && check_75 && check_98) {
                    main.removeEventListener('scroll', ScrollEvent);
                }
            }

            waitUntil(() => document.querySelector('main') != null).then(() => {
                const main = document.querySelector('main');
                main.addEventListener('scroll', () => ScrollEvent(main));
            });

        });
    }());
}
