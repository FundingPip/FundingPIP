                    }
                    // SIGN IN CTA & CONTINUE WITH GOOGLE - LOG IN PAGE
                    if (target.closest('button[type="submit"]')) {
                        const button = target.closest('button').textContent;
                        if (button.includes('Sign in')) {
                            // console.log('SIGN IN CTA ');
                            // convertGoal("100149925");
