                    gtagTracking("FP_02", "JOIN COMPETITON CLICK", "JOIN COMPETITON CLICK");
                }

                // INTERACTION WITH STEP CTA
                if (target.closest('#pricing-table .bg-step:first-child > div button')) {
                    const btn = target.closest('#pricing-table .bg-step:first-child > div button');
