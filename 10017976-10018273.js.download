                    const text = target.closest('div[data-radix-popper-content-wrapper] div[data-slot="dropdown-menu-content"] a,div[data-radix-popper-content-wrapper] div[data-slot="dropdown-menu-content"] button').textContent.trim();
                    convertGoal("100147522");
                    gtagTracking("FP_13", "INTERACTION WITH NAVIGATION BARS", `INTERACTION WITH NAVIGATION BARS ${text}`);
                }

                // INTERACTION WITH NAVIGATION BARS
                if (target.closest('div.flex nav.fixed a')) {
                    const text = target.closest('div.flex nav.fixed a').getAttribute('href');
                    convertGoal("100147522");
                    gtagTracking("FP_13", "INTERACTION WITH NAVIGATION BARS", `INTERACTION WITH NAVIGATION BARS ${text}`);
