                }

            });

            function getScrollPercent() {
                let h = document.documentElement,
                    b = document.body,
                    st = 'scrollTop',
                    sh = 'scrollHeight';
                return ((h[st] || b[st]) / ((h[sh] || b[sh]) - h.clientHeight)) * 100;
            }

            let check_25 = false;
            let check_50 = false;
            let check_75 = false;
            let check_98 = false;

            const ScrollEvent = () => {
                if (getScrollPercent() >= 25 && !check_25) {
                    check_25 = true;
                    convertGoal('100145388');
                    gtagTracking('FP_10', 'PAGE SCROLL', 'Scroll_25%');
                }
                if (getScrollPercent() >= 50 && !check_50) {
                    check_50 = true;
