                    convertGoal("100145399");
                    gtagTracking("FP_02", "click on buy challenge in mid fold in plan chart", "click on buy challenge in mid fold in plan chart");
                }

            });

            function getScrollPercent() {
                let h = document.documentElement,
                    b = document.body,
                    st = 'scrollTop',
                    sh = 'scrollHeight';
                return ((h[st] || b[st]) / ((h[sh] || b[sh]) - h.clientHeight)) * 100;
            }

            let check_25 = false;
            let check_50 = false;
            let check_75 = false;
            let check_98 = false;

            const ScrollEvent = () => {
                if (getScrollPercent() >= 25 && !check_25) {
                    check_25 = true;
                    convertGoal('100145388');
                    gtagTracking('FP_02', 'PAGE SCROLL', 'Scroll_25%');
                }
                if (getScrollPercent() >= 50 && !check_50) {
                    check_50 = true;
                    convertGoal('100145389');
                    gtagTracking('FP_02', 'PAGE SCROLL', 'Scroll_50%');
                }
                if (getScrollPercent() >= 75 && !check_75) {
                    check_75 = true;
                    convertGoal('100145390');
                    gtagTracking('FP_02', 'PAGE SCROLL', 'Scroll_75%');
                }
                if (getScrollPercent() >= 98 && !check_98) {
                    check_98 = true;
                    convertGoal('100145391');
                    gtagTracking('FP_02', 'PAGE SCROLL', 'Scroll_100%');
                }

                if (check_25 && check_50 && check_75 && check_98) {
                    window.removeEventListener('scroll', ScrollEvent);
                }
            };

            window.addEventListener('scroll', ScrollEvent);

            function triggerWhenInView(selector) {
                const targetElement = document.querySelector(selector);
                if (!targetElement) return;

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
                            convertGoal("100146893");
                            gtagTracking("FP_02", "view mid fold buy challenge cta", `view mid fold buy challenge cta`);
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: [1], rootMargin: '0px' });

                observer.observe(targetElement);
            }
            if (window.innerWidth < 768) {
                waitUntil(() => document.querySelectorAll('.bg-table .mb-6  div[class*="md:hidden"] > a[href="https://app.fundingpips.com/new-challenge"] button').length > 0).then(() => {
                    triggerWhenInView('.bg-table .mb-6  div[class*="md:hidden"] > a[href="https://app.fundingpips.com/new-challenge"] button');
                })
            } else {
                waitUntil(() => document.querySelectorAll('#pricing-table .bg-table .border-table-border .hidden > a[href="https://app.fundingpips.com/new-challenge"] button').length > 0).then(() => {
