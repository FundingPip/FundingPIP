                if (target.closest('#pricing-table .bg-step:nth-child(2) > div button')) {
                    const btn = target.closest('#pricing-table .bg-step:nth-child(2) > div button');
                    const label = btn.textContent.trim();
                    // console.log('interaction with normal and pro cta', label);
                    if (label.toLowerCase().includes('funding') && !document.body.classList.contains('fp_02')) {
                        convertGoal("100145397");
                        gtagTracking("FP_02", "interaction with normal and pro cta", `interaction with normal and pro cta ${label}`);
                    }
                }

