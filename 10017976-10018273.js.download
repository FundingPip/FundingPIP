/* eslint-disable */
if (!window.FP_16_TriggeredGlobal) {
    window.FP_16_TriggeredGlobal = true;
    (function trackingShared() {
        function gtagTracking(convert_category, convert_action, convert_label) {
            window.gtag('event', 'Convert_Test_Tracking', {
                convert_category,
                convert_action,
                convert_label,
                send_to: 'G-TFJP814ZR2'
            });
        }

        function delegateEvent(el, evt, sel, handler) {
            el.addEventListener(evt, function (event) {
                let t = event.target;
                while (t && t !== this) {
                    if (t.matches(sel)) {
                        event.matchedSelector = t;
                        handler.call(t, event);
                    }
                    t = t.parentNode;
                }
            }, true);
        }

        function waitUntil(predicate, time = 10000) {
            return new Promise(((resolve) => {
                let int = setInterval(() => {
                    if (predicate()) {
                        resolve(predicate());
                        clearInterval(int);
                        int = null;
                    }
                }, 30);
                setTimeout(() => {
                    if (int !== null) {
                        clearInterval(int);
                        console.log('condition false');
                    }
                }, time);
            }));
        }

        function convertGoal(id) {
            window._conv_q = window._conv_q || [];
            _conv_q.push(['triggerConversion', id]);
        }

        setTimeout(() => {

            delegateEvent(document, 'mousedown', 'body', ({ target }) => {

                // Interaction with Dashboard tab
                if (target.closest('div.flex nav.fixed a[href="/dashboard"]')) {
                    convertGoal("100151572");
                    gtagTracking("FP_16", "Interaction with Dashboard tab", 'Interaction with Dashboard tab');
                }

                // Interaction with Account tab
                if (target.closest('div.flex nav.fixed a[href="/accounts"]')) {
                    convertGoal("100151573");
                    gtagTracking("FP_16", "Interaction with Account tab", 'Interaction with Account tab');
                }

                // Interaction with Buy challenge tab
                if (target.closest('div.flex nav.fixed a[href="/new-challenge"]')) {
                    convertGoal("100151574");
                    gtagTracking("FP_16", "Interaction with Buy challenge tab", 'Interaction with Buy challenge tab');
                }

                // Interaction with more option items
                if (target.closest('[data-radix-popper-content-wrapper] [data-radix-menu-content] [role="menuitem"],[data-radix-popper-content-wrapper] [data-radix-menu-content] button[aria-label="Log out"]')) {
                    const text = target.closest('[data-radix-popper-content-wrapper] [data-radix-menu-content] [role="menuitem"]').textContent.trim();
                    convertGoal("100151576");
                    gtagTracking("FP_16", "Interaction with more option items", `Interaction with more option items ${text}`);
                }

                // CLICK ON CONTINUE PAYEMNT CTA
                if (target.closest('form section button[type="submit"]') && window.location.pathname === '/new-challenge') {
                    convertGoal("100147530");
                    gtagTracking("FP_16", "CLICK ON CONTINUE PAYEMNT CTA", "CLICK ON CONTINUE PAYEMNT CTA");
                }

                // ACCOUNT SIZES INTERACTION
                if (target.closest('form div[data-slot="radio-group"] label:has(button[value*="000"])') && window.location.pathname === '/new-challenge') {
                    const label = target.closest('label').querySelector('button').value;
                    convertGoal("100147533");
                    gtagTracking("FP_16", "ACCOUNT SIZES INTERACTION", `ACCOUNT SIZES INTERACTION - ${label}`);
                }

                // MODEL TYPES ( TWO STEP )
                if (target.closest('form label:has(button[value*="FundingPips"])') && window.location.pathname === '/new-challenge') {
                    const modelType = target.closest('label').querySelector('button').value;
                    convertGoal("100147523");
                    gtagTracking("FP_16", "MODEL TYPES ( TWO STEP )", `MODEL TYPES ( TWO STEP ) - ${modelType}`);
                }

                // challenge type clicks
                if (target.closest('form [data-slot="radio-group"] label:has(button[value*="Step"]), form [data-slot="radio-group"] label:has(button[value="Zero"])') && window.location.pathname === '/new-challenge') {
                    const challengeType = target.closest('label').querySelector('button').value.split(' ')[0];
                    convertGoal("100147534");
                    gtagTracking("FP_16", "challenge type clicks", `challenge type clicks - ${challengeType}`);
                }

                // INTERACTION WITH BILLING DETAIL FIELDS
                if (target.closest('[data-slot="popover-content"] [data-slot="command-item"][data-value]') && window.location.pathname === '/new-challenge') {
                    const isFormOpen = document.body.querySelector('main form #billing-details button[data-state="open"]');
                    if (isFormOpen) {
                        const label = target.closest('[data-slot="command-item"]').dataset.value;
                        convertGoal("100149895");
                        gtagTracking("FP_16", "INTERACTION WITH BILLING DETAIL FIELDS", `INTERACTION WITH BILLING DETAIL FIELDS - ${label}`);
                    }
                }

                // CLICK ON I AGREE CHECKBOX
                if (target.closest('form button#terms-agreement') && window.location.pathname === '/new-challenge') {
                    convertGoal("100147529");
                    gtagTracking("FP_16", "CLICK ON I AGREE CHECKBOX", "CLICK ON I AGREE CHECKBOX");
                }

                // TRADE PLATFROM INTERACTION
                if (target.closest('form div[data-slot="radio-group"] label:has(button[value*="mt5"]), form div[data-slot="radio-group"] label:has(button[value*="matchtrader"]), form div[data-slot="radio-group"] label:has(button[value*="ctrader"])') && window.location.pathname === '/new-challenge') {
                    const label = target.closest('label').querySelector('button').value;
                    convertGoal("100147532");
                    gtagTracking("FP_16", "TRADE PLATFROM INTERACTION", `TRADE PLATFROM INTERACTION - ${label}`);
                }

                // FUNDING PIP PROFIT TARGET INTERACTION
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:not(:has(+ div)) label') && window.location.pathname === '/new-challenge') {
                    const isProfitTarget = target.closest('div[role="radiogroup"]').closest('div:not([role="radiogroup"]').querySelector('label').textContent.includes('Profit Target');
                    if (isProfitTarget) {
                        const label = target.closest('label').querySelector('.text-sm').textContent;
                        convertGoal("100147524");
                        gtagTracking("FP_16", "FUNDING PIP PROFIT TARGET INTERACTION", `FUNDING PIP PROFIT TARGET INTERACTION - ${label}`);
                    }
                }

                // FUNDING PIP swap free interaction
                // FUNDINGPIP PRO swap free interaction
                if (target.closest('form > div > div.space-y-6 div[role="radiogroup"]:not(:has(+ div)) label') && window.location.pathname === '/new-challenge') {
                    const isSwapFree = target.closest('div[role="radiogroup"]').closest('div:not([role="radiogroup"]').querySelector('label').textContent.includes('Swap Free');
                    if (isSwapFree) {
                        const isProSelected = document.body.querySelector('form label:has(button[data-state="checked"][value*="Pro"])');
                        const label = target.closest('label').querySelector('.text-sm').textContent;
                        if (isProSelected) {
                            // FUNDINGPIP PRO swap free interaction
                            convertGoal("100151643");
                            gtagTracking("FP_16", "FUNDINGPIP PRO swap free interaction", `FUNDINGPIP PRO swap free interaction - ${label}`);
                        } else {
                            // FUNDING PIP swap free interaction
                            convertGoal("100149894");
                            gtagTracking("FP_16", "FUNDING PIP swap free interaction", `FUNDING PIP swap free interaction - ${label}`);
                        }
                    }
                }

            });

            delegateEvent(document, 'focusout', 'main form #billing-details input', ({ target }) => {
                if (window.location.pathname !== '/new-challenge') return;
                // INTERACTION WITH BILLING DETAIL FIELDS
                const inputValue = target.closest('input').value;
                convertGoal("100149895");
                gtagTracking("FP_16", "INTERACTION WITH BILLING DETAIL FIELDS", `INTERACTION WITH BILLING DETAIL FIELDS - ${inputValue}`);
            });

            delegateEvent(document, 'pointerdown', 'body', ({ target }) => {
                // Interaction with More options tab 
                if (target.closest('div.flex nav.fixed button[data-slot="dropdown-menu-trigger"]')) {
                    convertGoal("100151575");
                    gtagTracking("FP_16", "Interaction with More options tab", 'Interaction with More options tab ');
                }
            });

            // page scroll
            waitUntil(() => document.querySelector('main')).then(() => {

                const scrollContainer = document.querySelector('main');
                console.log(scrollContainer, 'scrollContainer');

                function getScrollPercent() {
                    console.log('inside percent');
                    const scrollTop = scrollContainer.scrollTop;
                    const scrollHeight = scrollContainer.scrollHeight - scrollContainer.clientHeight;
                    return (scrollTop / scrollHeight) * 100;
                }

                let check_25 = false;
                let check_50 = false;
                let check_75 = false;
                let check_98 = false;

                const ScrollEvent = () => {

                    const percent = getScrollPercent();

                    if (percent >= 25 && !check_25) {
                        check_25 = true;
                        convertGoal('100145388');
                        gtagTracking('FP_16', 'PAGE SCROLL', 'Scroll_25%');
                    }

                    if (percent >= 50 && !check_50) {
                        check_50 = true;
                        convertGoal('100145389');
                        gtagTracking('FP_16', 'PAGE SCROLL', 'Scroll_50%');
                    }

                    if (percent >= 75 && !check_75) {
                        check_75 = true;
                        convertGoal('100145390');
                        gtagTracking('FP_16', 'PAGE SCROLL', 'Scroll_75%');
                    }

                    if (percent >= 98 && !check_98) {
                        check_98 = true;
                        convertGoal('100145391');
                        gtagTracking('FP_16', 'PAGE SCROLL', 'Scroll_100%');
                    }

                    if (check_25 && check_50 && check_75 && check_98) {
                        scrollContainer.removeEventListener('scroll', ScrollEvent);
                    }
                };

                scrollContainer.addEventListener('scroll', ScrollEvent);

            });
        }, 2000);
    }());
}
