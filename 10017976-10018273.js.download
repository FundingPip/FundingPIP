                    const text = target.closest('.fp_13_share_btn, main div.flex button[data-slot="dialog-trigger"]').textContent.trim().toLowerCase();
                    if (!text.includes('share')) return;
                    convertGoal("100149764");
                    gtagTracking("FP_13", "SHARE CTA CLICK", "SHARE CTA CLICK");
                }

            });

            // page scroll (dashboard)
            waitUntil(() => document.querySelector('main')).then(() => {

                const scrollContainer = document.querySelector('main');
                console.log(scrollContainer,'scrollContainer');

                function getScrollPercent() {
                    console.log('inside percent');
                    const scrollTop = scrollContainer.scrollTop;
                    const scrollHeight = scrollContainer.scrollHeight - scrollContainer.clientHeight;
                    return (scrollTop / scrollHeight) * 100;
                }

                let check_25 = false;
                let check_50 = false;
                let check_75 = false;
                let check_98 = false;

                const ScrollEvent = () => {
                    if (window.location.pathname !== '/dashboard') return;
                    console.log('inside event');

                    const percent = getScrollPercent();

                    if (percent >= 25 && !check_25) {
                        check_25 = true;
                        convertGoal('100145388');
                        gtagTracking('FP_13', 'PAGE SCROLL', 'Scroll_25%');
                    }

                    if (percent >= 50 && !check_50) {
                        check_50 = true;
                        convertGoal('100145389');
                        gtagTracking('FP_13', 'PAGE SCROLL', 'Scroll_50%');
                    }

                    if (percent >= 75 && !check_75) {
                        check_75 = true;
                        convertGoal('100145390');
                        gtagTracking('FP_13', 'PAGE SCROLL', 'Scroll_75%');
                    }

                    if (percent >= 98 && !check_98) {
                        check_98 = true;
                        convertGoal('100145391');
                        gtagTracking('FP_13', 'PAGE SCROLL', 'Scroll_100%');
                    }

