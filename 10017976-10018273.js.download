                    if (label.toLowerCase().includes('zero') || label.toLowerCase().includes('step')) {
                        convertGoal("100145396");
                        gtagTracking("FP_02", "INTERACTION WITH STEP CTA", `INTERACTION WITH STEP CTA ${label}`);
                    }
                }

