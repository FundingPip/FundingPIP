                        // console.log('CREATE YOUR ACCOUNT INTERACTION - LOG IN PAGE ');
                        convertGoal("100149927");
                        gtagTracking("FP_14", "CREATE YOUR ACCOUNT INTERACTION - LOG IN PAGE", "Interaction");
                    }
                }
            });

            delegateEvent(document, 'change', 'body', ({ target }) => {
                // title
                if (target.closest('#title + select')) {
                    const title = target.options[target.selectedIndex].text;
                    // console.log('title', title);
                    convertGoal("100149901");
                    gtagTracking("FP_14", "title", title);
                }
                // date of birth
                if (target.closest('#date_of_birth')) {
                    const dateOfBirth = target.value;
                    // console.log('dateOfBirth', dateOfBirth);
                    convertGoal("100149902");
                    gtagTracking("FP_14", "date of birth", dateOfBirth);
