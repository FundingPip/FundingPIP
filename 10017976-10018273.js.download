                    check_98 = true;
                    convertGoal('100145391');
                    gtagTracking('FP_10', 'PAGE SCROLL', 'Scroll_100%');
                }

                if (check_25 && check_50 && check_75 && check_98) {
                    window.removeEventListener('scroll', ScrollEvent);
                }
            };

            window.addEventListener('scroll', ScrollEvent);

            function triggerWhenInView(selector) {
                const targetElement = document.querySelector(selector);
                if (!targetElement) return;

                const observer = new IntersectionObserver((entries) => {
                    console.log('entries', entries);
                    entries.forEach(entry => {
                        console.log('entry', entry);
                        if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
                            convertGoal("100146893");
                            gtagTracking("FP_10", "view mid fold buy challenge cta", `view mid fold buy challenge cta`);
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: [1], rootMargin: '0px' });

                observer.observe(targetElement);
            }
            if (window.innerWidth < 768) {
                waitUntil(() => document.querySelectorAll('.bg-table .mb-6  div[class*="md:hidden"] > a[href="https://app.fundingpips.com/new-challenge"] button').length > 0).then(() => {
                    triggerWhenInView('.bg-table .mb-6  div[class*="md:hidden"] > a[href="https://app.fundingpips.com/new-challenge"] button');
                })
            } else {
                waitUntil(() => document.querySelectorAll('#pricing-table .bg-table .border-table-border .hidden > a[href="https://app.fundingpips.com/new-challenge"] button').length > 0).then(() => {
                    triggerWhenInView('#pricing-table .bg-table .border-table-border .hidden > a[href="https://app.fundingpips.com/new-challenge"] button');
                })
            }


            waitUntil(() => document.querySelector('.bg-table') != null
